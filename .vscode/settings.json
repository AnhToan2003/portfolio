{
  "files.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/.git": true,
    "**/package-lock.json": true
  },
  "search.exclude": {
    "**/node_modules": true,
    "**/dist": true
  },
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.patterns": {
    "package.json": "package-lock.json",
    "*.env": ".env.example",
    "tailwind.config.js": "postcss.config.js",
    "vite.config.js": "vercel.json, netlify.toml"
  }
}
